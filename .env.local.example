# Copy this file to .env.local and fill in real values once Supabase is set up.
# Phase 1 (this scaffold) doesn't read these yet — the map runs on mock data.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (server-side email — match invites, vouch notifications)
# Generate at https://resend.com/api-keys (give it "Sending access")
RESEND_API_KEY=

# Public site URL used in email links (defaults to pklrally.com if unset)
NEXT_PUBLIC_SITE_URL=https://pklrally.com

# Mapbox public token (pk.*) — used by admin court-add autocomplete + static map preview.
# Sign up free at mapbox.com → Account → Tokens → copy "Default public token".
NEXT_PUBLIC_MAPBOX_TOKEN=

# Admin TOTP — set after first admin login
ADMIN_TOTP_ISSUER=PKLRALLY
